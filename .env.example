# App Config
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
GLOBAL_PREFIX=api

# Database Config
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=fx_exchange
DB_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fx_exchange
DB_SYNC=false
DB_POOL_MAX=20
DB_POOL_MIN=5

# Redis Config
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Security (use a strong key: openssl rand -hex 64)
JWT_SECRET=your-super-secret-key-change-in-production
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=10
LOCK_TTL_MS=10000

# Mail Config
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USER=your-email@domain.com
MAIL_PASS=your-mailbox-password
MAIL_FROM="FX Exchange <noreply@domain.com>"

# FX Rate Config
EXCHANGE_RATE_API_KEY=your-api-key-here
FX_RETRY_MAX=3
FX_RETRY_BASE_DELAY_MS=300
FX_REQUEST_TIMEOUT_MS=5000

# RabbitMQ Config (for outbox publishing)
RMQ_USER=guest
RMQ_PASS=guest
RMQ_PORT=5672
RMQ_MANAGEMENT_PORT=15672
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Outbox Config
OUTBOX_MAX_RETRIES=5
OUTBOX_BATCH_SIZE=50
OUTBOX_POLL_INTERVAL_MS=2000
