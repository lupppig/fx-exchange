# App Config
NODE_ENV=development
PORT=3000
GLOBAL_PREFIX=api

# Database Config
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fx_exchange
DB_SYNC=false
DB_POOL_MAX=20
DB_POOL_MIN=5

# Redis Config
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=your-super-secret-key
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=10

# Mail Config
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USER=your-email@domain.com
MAIL_PASS=your-mailbox-password
MAIL_FROM="FX Exchange <noreply@domain.com>"

# FX Rate Config
EXCHANGE_RATE_API_KEY=your-api-key-here
