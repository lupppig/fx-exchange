# App Config
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
GLOBAL_PREFIX=api

# Database Config
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=fx_exchange
DB_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fx_exchange
DB_SYNC=true
DB_POOL_MAX=20
DB_POOL_MIN=5

# Redis Config
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=your-super-secret-key
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=10

# Mail Config
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USER=your-email@domain.com
MAIL_PASS=your-mailbox-password
MAIL_FROM="FX Exchange <noreply@domain.com>"

# FX Rate Config
EXCHANGE_RATE_API_KEY=your-api-key-here
FX_RETRY_MAX=3
FX_RETRY_BASE_DELAY_MS=300
FX_REQUEST_TIMEOUT_MS=5000

# RabbitMQ Config
RMQ_USER=guest
RMQ_PASS=guest
RMQ_PORT=5672
RMQ_MANAGEMENT_PORT=15672
RABBITMQ_URL=amqp://guest:guest@localhost:5672
